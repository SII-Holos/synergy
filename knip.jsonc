{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    "dist/**",
    ".turbo/**",
    ".synergy/**",
    "node_modules/**",
    "coverage/**",
    "research/**",
    "awcp-paper/**",
    "holos-paper/**",
    "packages/**/dist/**",
    "packages/**/release/**",
    "packages/sdk/js/src/gen/**",
    "packages/synergy/test/tool/fixtures/large-image.png",
  ],
  "ignoreDependencies": [
    "@ericsanchezok/synergy-plugin",
    "@ericsanchezok/synergy-script",
    "@ericsanchezok/synergy-sdk",
    "@napi-rs/canvas",
    "@scope/plugin",
    "playwright",
    "@shikijs/transformers",
    "@solid-primitives/bounds",
    "@solid-primitives/scroll",
    "@solid-primitives/websocket",
    "@tiptap/extension-floating-menu",
    "cropperjs",
    "diff",
    "fuzzysort",
    "katex",
    "marked",
    "marked-shiki",
    "solid-list",
    "solid-tiptap",
    "tailwindcss",
    "virtua",
    "@ai-sdk/provider-utils",
    "@hono/zod-validator",
    "@huggingface/transformers",
    "chromium-bidi",
    "mammoth",
    "tree-sitter-bash",
    "xlsx",
    "turbo",
    "@tsconfig/bun",
    "@tsconfig/node22",
    "vite-plugin-icons-spritesheet",
    "@tailwindcss/vite",
    "@ast-grep/cli-darwin-arm64",
    "@ast-grep/cli-darwin-x64",
    "@ast-grep/cli-linux-arm64-gnu",
    "@ast-grep/cli-linux-x64-gnu",
    "@ast-grep/cli-win32-x64-msvc",
    "@parcel/watcher-darwin-arm64",
    "@parcel/watcher-darwin-x64",
    "@parcel/watcher-linux-arm64-glibc",
    "@parcel/watcher-linux-arm64-musl",
    "@parcel/watcher-linux-x64-glibc",
    "@parcel/watcher-linux-x64-musl",
    "@parcel/watcher-win32-arm64",
    "@parcel/watcher-win32-x64",
    "sqlite-vec-darwin-arm64",
    "sqlite-vec-darwin-x64",
    "sqlite-vec-linux-arm64",
    "sqlite-vec-linux-x64",
    "sqlite-vec-windows-x64",
  ],
  "ignoreBinaries": [
    "swiftc",
    "codesign",
    "hdiutil",
    "sips",
    "iconutil",
    "taskkill",
    "which",
    "gh",
    "dev",
    "synergy",
    "build",
    "brew",
    "install",
    "run",
    "mix",
    "xcrun",
    "java",
    "powershell",
    "mode",
    "start",
    "stop",
    "latest",
    "gitleaks",
    "uvx",
    "rg",
    "linux",
    "windows",
    "cat-file",
    "rev-parse",
    "pkg",
    "HEAD",
  ],
  "ignoreUnresolved": [".json", ".svg", "\\.po\\?lingui$"],
  "rules": {
    "catalog": "off",
  },
  "workspaces": {
    "packages/synergy": {
      "entry": ["bin/synergy", "script/**/*.ts", "scripts/**/*.ts", "test/**/*.ts"],
      "project": ["src/**/*.ts", "script/**/*.ts", "scripts/**/*.ts", "test/**/*.ts"],
    },
    "packages/app": {
      "entry": ["lingui.config.ts", "src/**/*.{ts,tsx}", "script/**/*.ts"],
      "project": ["src/**/*.{ts,tsx}", "script/**/*.ts"],
    },
    "packages/desktop": {
      "entry": ["script/**/*.ts", "test/**/*.ts"],
      "project": ["src/**/*.ts", "script/**/*.ts", "test/**/*.ts"],
    },
    "packages/ui": {
      "entry": [
        "src/components/**/*.{ts,tsx}",
        "src/context/**/*.{ts,tsx}",
        "src/hooks/**/*.ts",
        "src/plugin/**/*.ts",
        "src/pierre/**/*.ts",
        "src/theme/**/*.ts",
        "script/**/*.ts",
        "test/**/*.ts",
      ],
      "project": ["src/**/*.{ts,tsx}", "script/**/*.ts", "test/**/*.ts"],
    },
    "packages/sdk/js": {
      "entry": ["script/**/*.ts"],
      "project": ["src/**/*.ts", "script/**/*.ts"],
    },
    "packages/plugin": {
      "project": ["src/**/*.ts"],
    },
    "packages/plugin-kit": {
      "entry": ["test/**/*.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"],
    },
    "packages/util": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"],
    },
  },
}
