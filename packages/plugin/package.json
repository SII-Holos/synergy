{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@ericsanchezok/synergy-plugin",
  "version": "1.1.26",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SII-Holos/synergy.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "build": "tsc"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./tool": {
      "bun": "./src/tool.ts",
      "types": "./src/tool.ts",
      "import": "./dist/tool.js"
    },
    "./display": {
      "bun": "./src/display.ts",
      "types": "./src/display.ts",
      "import": "./dist/display.js"
    },
    "./hooks": {
      "bun": "./src/hooks.ts",
      "types": "./src/hooks.ts",
      "import": "./dist/hooks.js"
    },
    "./permissions": {
      "bun": "./src/permissions.ts",
      "types": "./src/permissions.ts",
      "import": "./dist/permissions.js"
    },
    "./ids": {
      "bun": "./src/ids.ts",
      "types": "./src/ids.ts",
      "import": "./dist/ids.js"
    },
    "./policy": {
      "bun": "./src/policy.ts",
      "types": "./src/policy.ts",
      "import": "./dist/policy.js"
    },
    "./market": {
      "bun": "./src/market.ts",
      "types": "./src/market.ts",
      "import": "./dist/market.js"
    },
    "./spec": {
      "bun": "./src/spec.ts",
      "types": "./src/spec.ts",
      "import": "./dist/spec.js"
    },
    "./shell": {
      "bun": "./src/shell.ts",
      "types": "./src/shell.ts",
      "import": "./dist/shell.js"
    },
    "./ui": {
      "bun": "./src/ui.ts",
      "types": "./src/ui.ts",
      "import": "./dist/ui.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {},
  "peerDependencies": {
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@ericsanchezok/synergy-sdk": "workspace:*",
    "@tsconfig/node22": "catalog:",
    "@types/node": "catalog:",
    "solid-js": "catalog:",
    "typescript": "catalog:",
    "@typescript/native-preview": "catalog:",
    "zod": "catalog:"
  }
}
