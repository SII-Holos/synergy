{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@ericsanchezok/synergy-plugin",
  "version": "1.2.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SII-Holos/synergy.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "build": "bun run --cwd ../util build && rm -rf dist && tsc -p tsconfig.build.json"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./tool": {
      "bun": "./src/tool.ts",
      "types": "./src/tool.ts",
      "import": "./dist/tool.js"
    },
    "./display": {
      "bun": "./src/display.ts",
      "types": "./src/display.ts",
      "import": "./dist/display.js"
    },
    "./ids": {
      "bun": "./src/ids.ts",
      "types": "./src/ids.ts",
      "import": "./dist/ids.js"
    },
    "./paths": {
      "bun": "./src/paths.ts",
      "types": "./src/paths.ts",
      "import": "./dist/paths.js"
    },
    "./artifact": {
      "bun": "./src/artifact.ts",
      "types": "./src/artifact.ts",
      "import": "./dist/artifact.js"
    },
    "./market": {
      "bun": "./src/market.ts",
      "types": "./src/market.ts",
      "import": "./dist/market.js"
    },
    "./version": {
      "bun": "./src/version.ts",
      "types": "./src/version.ts",
      "import": "./dist/version.js"
    },
    "./loader": {
      "bun": "./src/loader.ts",
      "types": "./src/loader.ts",
      "import": "./dist/loader.js"
    },
    "./shell": {
      "bun": "./src/shell.ts",
      "types": "./src/shell.ts",
      "import": "./dist/shell.js"
    },
    "./ui": {
      "bun": "./src/ui.ts",
      "types": "./src/ui.ts",
      "import": "./dist/ui.js"
    },
    "./auth": {
      "bun": "./src/auth-types.ts",
      "types": "./src/auth-types.ts",
      "import": "./dist/auth-types.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@ericsanchezok/synergy-sdk": "workspace:*"
  },
  "peerDependencies": {
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@tsconfig/node22": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:",
    "zod": "catalog:"
  }
}
