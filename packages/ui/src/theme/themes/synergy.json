      "markdown-horizontal-rule": "#48484A",
      "markdown-list-item": "#0A84FF",
      "markdown-list-enumeration": "#6BDFFF",
      "markdown-image": "#0A84FF",
      "markdown-image-text": "#6BDFFF",
      "markdown-code-block": "#F5F5F7",

      "avatar-background-pink": "#3A1325",
      "avatar-background-mint": "#0A2E2C",
      "avatar-background-orange": "#3A2208",
      "avatar-background-purple": "#2A1541",
      "avatar-background-cyan": "#0A1E3A",
      "avatar-background-lime": "#1A2E0E",
      "avatar-text-pink": "#FF375F",
      "avatar-text-mint": "#63E6E2",
      "avatar-text-orange": "#FF9F0A",
      "avatar-text-purple": "#BF5AF2",
