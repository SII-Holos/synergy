      "avatar-text-orange": "#FF9500",
      "avatar-text-purple": "#AF52DE",
      "avatar-text-cyan": "#007AFF",
      "avatar-text-lime": "#28CD41"
    }
  },
  "dark": {
    "seeds": {
      "neutral": "#86868B",
      "primary": "#0A84FF",
      "success": "#32D74B",
      "warning": "#FFD60A",
      "error": "#FF453A",
      "info": "#5E5CE6",
      "interactive": "#0A84FF",
      "diffAdd": "#32D74B",
      "diffDelete": "#FF453A"
