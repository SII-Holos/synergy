{
  "$schema": "./theme.schema.json",
  "name": "Synergy",
  "id": "synergy",
  "light": {
    "seeds": {
      "neutral": "#86868B",
      "primary": "#007AFF",
      "success": "#28CD41",
      "warning": "#FF9500",
      "error": "#FF3B30",
      "info": "#5856D6",
      "interactive": "#007AFF",
      "diffAdd": "#28CD41",
      "diffDelete": "#FF3B30"
    },
    "overrides": {
      "background-base": "#FFFFFF",
      "background-weak": "#F5F5F7",
      "background-strong": "#FFFFFF",
      "background-stronger": "#FFFFFF",

      "surface-float-base": "#1D1D1F",
      "surface-float-base-hover": "#2C2C2E",

      "button-secondary-base": "#F5F5F7",
      "button-secondary-hover": "#E8E8ED",

      "border-color": "#FFFFFF",

      "syntax-comment": "var(--text-weaker)",
      "syntax-regexp": "var(--text-base)",
      "syntax-string": "#C41A16",
      "syntax-keyword": "#9B2393",
      "syntax-primitive": "#1C00CF",
      "syntax-operator": "var(--text-base)",
      "syntax-variable": "var(--text-strong)",
      "syntax-property": "#326D74",
      "syntax-type": "#0B4F79",
      "syntax-constant": "#1C00CF",
      "syntax-punctuation": "var(--text-base)",
      "syntax-object": "var(--text-strong)",
      "syntax-info": "#0B4F79",
      "syntax-diff-unknown": "#FF3B30",

      "markdown-heading": "#1D1D1F",
      "markdown-text": "#1D1D1F",
      "markdown-link": "#007AFF",
      "markdown-link-text": "#0B4F79",
      "markdown-code": "#C41A16",
      "markdown-block-quote": "#86868B",
      "markdown-emph": "#9B2393",
      "markdown-strong": "#1D1D1F",
      "markdown-horizontal-rule": "#D1D1D6",
      "markdown-list-item": "#007AFF",
      "markdown-list-enumeration": "#0B4F79",
      "markdown-image": "#007AFF",
      "markdown-image-text": "#0B4F79",
      "markdown-code-block": "#1D1D1F",

      "avatar-background-pink": "#FFF0F5",
      "avatar-background-mint": "#E5FBF8",
      "avatar-background-orange": "#FFF3E6",
      "avatar-background-purple": "#F6F0FE",
      "avatar-background-cyan": "#ECF4FF",
      "avatar-background-lime": "#ECFAE6",
      "avatar-text-pink": "#FF2D55",
