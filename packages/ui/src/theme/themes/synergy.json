      "background-stronger": "#0A0A0C",

      "surface-float-base": "#1C1C1E",
      "surface-float-base-hover": "#2C2C2E",

      "button-secondary-base": "#1C1C1E",
      "button-secondary-hover": "#2C2C2E",

      "border-color": "#000000",

      "syntax-comment": "var(--text-weaker)",
      "syntax-regexp": "var(--text-base)",
      "syntax-string": "#FF8170",
      "syntax-keyword": "#FF7AB2",
      "syntax-primitive": "#D0A8FF",
      "syntax-operator": "var(--text-weak)",
      "syntax-variable": "var(--text-strong)",
      "syntax-property": "#ACF2E4",
      "syntax-type": "#6BDFFF",
      "syntax-constant": "#D0BF69",
      "syntax-punctuation": "var(--text-weak)",
      "syntax-object": "var(--text-strong)",
      "syntax-info": "#6BDFFF",
      "syntax-diff-unknown": "#FF453A",

      "markdown-heading": "#F5F5F7",
      "markdown-text": "#F5F5F7",
