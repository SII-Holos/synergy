{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM"],
    "types": ["node"],
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "declaration": true,
    "noEmit": false,
    "strict": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@ericsanchezok/meta-protocol": ["../meta-protocol/src/index.ts"]
    }
  },
  "include": ["src"]
}
