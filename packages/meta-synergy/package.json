{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@ericsanchezok/meta-synergy",
  "version": "1.1.26",
  "type": "module",
  "license": "MIT",
  "bin": {
    "meta-synergy": "./src/cli.ts"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "bun": "./src/*.ts",
      "types": "./src/*.ts",
      "import": "./dist/*.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@ericsanchezok/meta-protocol": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tsconfig/node22": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
