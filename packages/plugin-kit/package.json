{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@ericsanchezok/synergy-plugin-kit",
  "version": "1.1.26",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SII-Holos/synergy.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "bin": {
    "synergy-plugin": "./dist/cli.js",
    "synergy-plugin-kit": "./dist/cli.js"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "build": "bun run --cwd ../plugin build && rm -rf dist && tsc -p tsconfig.build.json"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./commands": {
      "bun": "./src/commands/index.ts",
      "types": "./src/commands/index.ts",
      "import": "./dist/commands/index.js"
    },
    "./market-entry": {
      "bun": "./src/lib/market-entry.ts",
      "types": "./src/lib/market-entry.ts",
      "import": "./dist/lib/market-entry.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@babel/core": "catalog:",
    "@babel/preset-typescript": "catalog:",
    "@ericsanchezok/synergy-plugin": "workspace:*",
    "babel-preset-solid": "catalog:",
    "yargs": "18.0.0"
  },
  "peerDependencies": {
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "catalog:",
    "@tsconfig/node22": "catalog:",
    "@types/babel__core": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@types/yargs": "17.0.33",
    "@typescript/native-preview": "catalog:",
    "solid-js": "catalog:",
    "typescript": "catalog:",
    "zod": "catalog:"
  }
}
