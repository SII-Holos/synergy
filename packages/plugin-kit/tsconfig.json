{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "preserve",
    "declaration": true,
    "moduleResolution": "bundler",
    "types": ["bun", "node"],
    "lib": ["es2022", "dom", "dom.iterable"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "paths": {
      "@ericsanchezok/synergy-util/*": ["../util/src/*.ts"]
    }
  },
  "include": ["src"]
}
