{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@ericsanchezok/synergy-browser",
  "version": "1.1.26",
  "private": true,
  "type": "module",
  "license": "MIT",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./*": {
      "bun": "./src/*.ts",
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test test/*.test.ts"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  }
}
