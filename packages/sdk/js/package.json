{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@ericsanchezok/synergy-sdk",
  "version": "1.1.26",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SII-Holos/synergy.git"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "build": "./script/build.ts"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "bun": "./src/client.ts",
      "types": "./src/client.ts",
      "import": "./dist/client.js"
    },
    "./server": {
      "bun": "./src/server.ts",
      "types": "./src/server.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@hey-api/openapi-ts": "0.88.1",
    "@tsconfig/node22": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "@typescript/native-preview": "catalog:"
  },
  "dependencies": {},
  "publishConfig": {
    "directory": "dist",
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
