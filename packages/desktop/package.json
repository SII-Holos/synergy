{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@ericsanchezok/synergy-desktop",
  "version": "1.1.26",
  "type": "module",
  "license": "MIT",
  "main": "./dist/main.js",
  "scripts": {
    "build": "bun build src/main.ts src/preload.ts --outdir dist --target=node --external electron",
    "dev": "bun run build && electron dist/main.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ericsanchezok/synergy-util": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "electron": "42.5.0",
    "typescript": "catalog:"
  }
}
